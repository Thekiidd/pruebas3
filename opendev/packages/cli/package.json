{
  "name": "openjupiter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "openjupiter": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@opendev/core": "workspace:*",
    "commander": "^12.1.0",
    "ink": "^5.0.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0",
    "ts-node": "^10.9.0"
  }
}
